{
  "name": "unictl",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/siren403/unictl.git"
  },
  "type": "module",
  "files": [
    "dist/",
    "packages/upm/com.unictl.editor/",
    "docs/standalone/",
    "integrations/"
  ],
  "workspaces": ["packages/cli"],
  "bin": {
    "unictl": "./dist/unictl.js"
  },
  "scripts": {
    "build": "./scripts/build/build-cli.sh",
    "build:cli": "./scripts/build/build-cli.sh",
    "build:native:macos": "./scripts/build/build-native-macos.sh",
    "version:fanout": "bun run ./scripts/version/fanout.ts",
    "version:check": "bun run ./scripts/version/drift-check.ts",
    "release:assemble": "bun run ./scripts/release/assemble.ts",
    "release:prepare": "bun run build && bun run version:fanout && bun run version:check && bun run release:assemble"
  }
}
