{
  "schema_version": 1,
  "unictl_version": "0.7.7",
  "subcommands": [
    {
      "name": "build",
      "description": "Build a Unity player (auto-routes between live editor via IPC and headless batchmode).",
      "key_flags": [
        "--target",
        "--output",
        "--build-profile",
        "--batch",
        "--wait"
      ],
      "help": "unictl build --help"
    },
    {
      "name": "compile",
      "description": "Headless batchmode compile + .meta generation.",
      "key_flags": [
        "--project",
        "--timeout"
      ],
      "help": "unictl compile --help"
    },
    {
      "name": "command",
      "description": "Invoke a builtin tool exposed by the Unity Editor via IPC.",
      "key_flags": [
        "-p",
        "@file"
      ],
      "help": "unictl command list (requires live editor)"
    },
    {
      "name": "describe-all",
      "description": "Emit canonical agent metadata for every v0.7 verb-noun command.",
      "key_flags": [],
      "help": "unictl describe-all"
    },
    {
      "name": "doctor",
      "description": "Environment diagnostics. Returns typed error.kind on failure.",
      "key_flags": [
        "--project"
      ],
      "help": "unictl doctor --help"
    },
    {
      "name": "editor",
      "description": "Unity editor lifecycle and live editor control (status | open | quit | restart | compile | play | stop | refresh).",
      "key_flags": [
        "--project"
      ],
      "help": "unictl editor --help",
      "subcommands": [
        {
          "name": "status",
          "description": "Show Unity editor running status.",
          "key_flags": [
            "--project"
          ],
          "help": "unictl editor status --help"
        },
        {
          "name": "open",
          "description": "Open the Unity editor; supports --wait [idle|playing|compiling|reloading|reachable] and --timeout.",
          "key_flags": [
            "--project",
            "--skip-precompile",
            "--wait",
            "--timeout"
          ],
          "help": "unictl editor open --help"
        },
        {
          "name": "quit",
          "description": "Quit the Unity editor.",
          "key_flags": [
            "--project",
            "--force",
            "--timeout"
          ],
          "help": "unictl editor quit --help"
        },
        {
          "name": "restart",
          "description": "Restart the Unity editor.",
          "key_flags": [
            "--project"
          ],
          "help": "unictl editor restart --help"
        },
        {
          "name": "compile",
          "description": "Trigger in-editor recompile; supports --wait [idle|playing|compiling|reloading|reachable] and --timeout.",
          "key_flags": [
            "--project",
            "--wait",
            "--timeout"
          ],
          "help": "unictl editor compile --help",
          "describe": "unictl editor compile --describe"
        },
        {
          "name": "play",
          "description": "Enter Play Mode; supports --wait [idle|playing|compiling|reloading|reachable] and --timeout.",
          "key_flags": [
            "--project",
            "--wait",
            "--timeout"
          ],
          "help": "unictl editor play --help",
          "describe": "unictl editor play --describe"
        },
        {
          "name": "stop",
          "description": "Exit Play Mode; supports --wait [idle|playing|compiling|reloading|reachable] and --timeout.",
          "key_flags": [
            "--project",
            "--wait",
            "--timeout"
          ],
          "help": "unictl editor stop --help",
          "describe": "unictl editor stop --describe"
        },
        {
          "name": "refresh",
          "description": "Run AssetDatabase.Refresh; supports --wait [idle|playing|compiling|reloading|reachable] and --timeout.",
          "key_flags": [
            "--project",
            "--wait",
            "--timeout"
          ],
          "help": "unictl editor refresh --help",
          "describe": "unictl editor refresh --describe"
        }
      ]
    },
    {
      "name": "health",
      "description": "Lightweight IPC ping against the live editor.",
      "key_flags": [
        "--project"
      ],
      "help": "unictl health --help"
    },
    {
      "name": "init",
      "description": "Add or update the com.unictl.editor manifest reference. Unity resolves/imports it on editor refresh, editor restart, or batch compile.",
      "key_flags": [
        "--project",
        "--repo-url"
      ],
      "help": "unictl init --help"
    },
    {
      "name": "input",
      "description": "Unity Input System lifecycle commands.",
      "key_flags": [
        "--project",
        "--restart"
      ],
      "help": "unictl input --help",
      "subcommands": [
        {
          "name": "set",
          "description": "Switch the Unity Input System handler (legacy | new | both).",
          "key_flags": [
            "--project",
            "--restart"
          ],
          "help": "unictl input set --help",
          "describe": "unictl input set --describe"
        }
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy and signing-time settings.",
      "key_flags": [
        "--project"
      ],
      "help": "unictl deploy --help",
      "subcommands": [
        {
          "name": "android",
          "description": "Android-specific deploy commands.",
          "key_flags": [
            "--project"
          ],
          "help": "unictl deploy android --help",
          "subcommands": [
            {
              "name": "keystore",
              "description": "Android keystore commands.",
              "key_flags": [
                "--project"
              ],
              "help": "unictl deploy android keystore --help",
              "subcommands": [
                {
                  "name": "set",
                  "description": "Configure Android keystore path and alias.",
                  "key_flags": [
                    "--project",
                    "--path",
                    "--alias"
                  ],
                  "help": "unictl deploy android keystore set --help",
                  "describe": "unictl deploy android keystore set --describe"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "scripting",
      "description": "Unity scripting backend settings.",
      "key_flags": [
        "--project",
        "--platform"
      ],
      "help": "unictl scripting --help",
      "subcommands": [
        {
          "name": "set",
          "description": "Toggle scripting backend (mono | il2cpp) per platform.",
          "key_flags": [
            "--project",
            "--platform"
          ],
          "help": "unictl scripting set --help",
          "describe": "unictl scripting set --describe"
        }
      ]
    },
    {
      "name": "settings",
      "description": "Unity project settings escape hatches.",
      "key_flags": [
        "--project"
      ],
      "help": "unictl settings --help",
      "subcommands": [
        {
          "name": "raw-set",
          "description": "Edit a Unity project setting by raw key; requires --no-warranty.",
          "key_flags": [
            "--project",
            "--no-warranty"
          ],
          "help": "unictl settings raw-set --help",
          "describe": "unictl settings raw-set --describe"
        }
      ]
    },
    {
      "name": "wait",
      "description": "Block until the editor reaches a target state.",
      "key_flags": [
        "--project",
        "--timeout"
      ],
      "help": "unictl wait --help",
      "describe": "unictl wait --describe"
    },
    {
      "name": "version",
      "description": "Print unictl CLI version.",
      "key_flags": [],
      "help": "unictl version"
    },
    {
      "name": "capabilities",
      "description": "Print offline capabilities JSON (this document).",
      "key_flags": [],
      "help": "unictl capabilities"
    },
    {
      "name": "test",
      "description": "Run Unity tests. Auto-routes to editor lane (IPC) when editor is running; falls back to batchmode with --batch. Without --batch and editor not running, returns editor_not_running error.",
      "key_flags": [
        "--batch",
        "--platform",
        "--results",
        "--filter",
        "--timeout",
        "--allow-unsaved-scenes",
        "--allow-reload-active"
      ],
      "help": "unictl test --help",
      "exit_codes": [
        {
          "code": 0,
          "kind": "success"
        },
        {
          "code": 1,
          "kind": "tests_failed"
        },
        {
          "code": 2,
          "kind": "editor_lane_unavailable"
        },
        {
          "code": 3,
          "kind": "no_assemblies"
        },
        {
          "code": 4,
          "kind": "xml_parse_failed"
        },
        {
          "code": 5,
          "kind": "unity_crash"
        },
        {
          "code": 6,
          "kind": "test_timeout"
        },
        {
          "code": 7,
          "kind": "test_invalid_filter"
        },
        {
          "code": 8,
          "kind": "unknown_test_failure"
        },
        {
          "code": 3,
          "kind": "editor_not_running"
        },
        {
          "code": 10,
          "kind": "editor_busy_compiling"
        },
        {
          "code": 11,
          "kind": "editor_busy_updating"
        },
        {
          "code": 12,
          "kind": "editor_busy_playing"
        },
        {
          "code": 13,
          "kind": "editor_dirty_scene"
        },
        {
          "code": 14,
          "kind": "editor_dirty_prefab_stage"
        },
        {
          "code": 15,
          "kind": "editor_reload_active"
        },
        {
          "code": 16,
          "kind": "results_path_unwritable"
        },
        {
          "code": 17,
          "kind": "test_already_running"
        },
        {
          "code": 18,
          "kind": "editor_died"
        },
        {
          "code": 19,
          "kind": "editor_session_changed"
        },
        {
          "code": 20,
          "kind": "test_heartbeat_stale"
        }
      ],
      "notes": [
        "Unity native exit codes are NOT trusted directly; unictl remaps based on XML + stderr patterns.",
        "Editor lane (v0.6.0+): --batch omitted + editor running → IPC via test_run tool. Poll Library/unictl-tests/<job-id>.json for progress.",
        "Batchmode lane: --batch required or editor not running → headless Unity process."
      ]
    }
  ],
  "builtins": [
    {
      "name": "test_run",
      "description": "Run Unity tests via TestRunnerApi (editor lane). Returns {ok,job_id,state:'queued'} immediately. Poll Library/unictl-tests/<job-id>.json for progress.",
      "parameters": [
        "platform",
        "assembly",
        "test_filter",
        "results_path",
        "job_id",
        "timeout_deadline_ms",
        "allow_unsaved_scenes",
        "allow_reload_active"
      ],
      "required_parameters": [
        "platform",
        "results_path",
        "job_id"
      ],
      "parameter_details": {
        "platform": {
          "type": "enum",
          "values": [
            "editmode",
            "playmode"
          ]
        },
        "assembly": {
          "type": "string",
          "description": "Assembly filter (optional)"
        },
        "test_filter": {
          "type": "string",
          "description": "Unity -testFilter expression (optional)"
        },
        "results_path": {
          "type": "string",
          "description": "Absolute path for NUnit XML output"
        },
        "job_id": {
          "type": "string",
          "description": "Caller-assigned UUID for progress file naming"
        },
        "timeout_deadline_ms": {
          "type": "number",
          "description": "Optional wall-clock deadline in ms"
        },
        "allow_unsaved_scenes": {
          "type": "boolean",
          "description": "Bypass dirty-scene preflight for PlayMode"
        },
        "allow_reload_active": {
          "type": "boolean",
          "description": "Force PlayMode + Full Reload (dangerous; may hang)"
        }
      },
      "response_fields": [
        "ok",
        "job_id",
        "state",
        "progress_file",
        "editor_session_id",
        "editor_pid"
      ],
      "emits_error_kinds": [
        "invalid_param",
        "editor_busy_compiling",
        "editor_busy_updating",
        "editor_busy_playing",
        "editor_dirty_scene",
        "editor_dirty_prefab_stage",
        "editor_reload_active",
        "results_path_unwritable",
        "test_already_running"
      ],
      "emitted_from": "editor_lane",
      "unity_version": "2022.3+"
    },
    {
      "name": "build_project",
      "description": "Build a Unity player; dual-lane auto-routing.",
      "parameters": [
        "target",
        "build_path",
        "scenes",
        "define_symbols",
        "build_profile",
        "options",
        "env",
        "timeout_sec",
        "log_level",
        "job_id"
      ],
      "companions": [
        "build_status",
        "build_cancel"
      ],
      "emits_error_kinds": [
        "invalid_param",
        "target_unsupported",
        "editor_busy",
        "project_locked",
        "multi_instance",
        "editor_running",
        "profile_switch_requires_batch",
        "profile_unsupported_on_this_unity",
        "profile_not_applied"
      ],
      "unity_version": "2022.3+ (BuildProfile requires 6000.0+)"
    },
    {
      "name": "build_status",
      "description": "Read progress file for a given job_id.",
      "parameters": [
        "job_id"
      ],
      "companions": [
        "build_project",
        "build_cancel"
      ],
      "emits_error_kinds": [
        "job_not_found",
        "progress_read_failed",
        "invalid_param"
      ],
      "unity_version": "2022.3+"
    },
    {
      "name": "build_cancel",
      "description": "Cooperative queue-stage cancellation.",
      "parameters": [
        "job_id"
      ],
      "companions": [
        "build_project",
        "build_status"
      ],
      "emits_error_kinds": [
        "invalid_param",
        "not_cancellable",
        "cancelled_by_user"
      ],
      "unity_version": "2022.3+"
    }
  ],
  "exit_codes": [
    {
      "code": 0,
      "meaning": "success"
    },
    {
      "code": 1,
      "meaning": "build failed / operation failed"
    },
    {
      "code": 2,
      "meaning": "param / validation error"
    },
    {
      "code": 3,
      "meaning": "lane unavailable / dependency missing"
    },
    {
      "code": 124,
      "meaning": "--wait client timeout (build continues)"
    },
    {
      "code": 125,
      "meaning": "unictl internal error"
    }
  ],
  "transports": [
    {
      "platform": "windows",
      "transport": "named_pipe",
      "path_pattern": "\\\\\\\\.\\\\pipe\\\\unictl-<sha256_hash>"
    },
    {
      "platform": "darwin",
      "transport": "unix_socket",
      "path_pattern": "/tmp/unictl-<sha256_hash>.sock"
    },
    {
      "platform": "linux",
      "transport": "unix_socket",
      "path_pattern": "/tmp/unictl-<sha256_hash>.sock"
    }
  ],
  "known_limitations": [
    "Third-party EditorApplication.Exit hooks can kill IPC-lane builds; use --batch to avoid.",
    "Target / scripting-define switches need manual editor restart or --batch with -buildTarget.",
    "build_cancel is cooperative at queue stage only; BuildPipeline.BuildPlayer has no interrupt API.",
    "Non-terminal progress files are not auto-recovered; clear Library/unictl-builds/ and re-run.",
    "Avoid running two unictl-initiated batch Unity instances on the same project."
  ],
  "references": {
    "changelog": "CHANGELOG.md",
    "migration": "MIGRATION.md",
    "deprecation": "DEPRECATION.md",
    "error_reference": "docs/standalone/error-reference.md",
    "security_model": "docs/standalone/security-model.md",
    "consumer_guide": "docs/standalone/consumer-guide.md",
    "workflows": "docs/standalone/WORKFLOWS.md"
  }
}
